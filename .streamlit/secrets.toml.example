# Скопируйте в secrets.toml (не коммитьте в git):
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml

[auth]
enabled = true
# Случайная длинная строка (подпись сессии)
secret_key = "замените-на-случайную-строку-32+символов"
# Регистрация через UI (логин + пароль, без подтверждения email)
allow_registration = true
# Гостевой вход без аккаунта (отключено по умолчанию)
allow_guest = false
require_email_verification = false
# Страницы для новых пользователей и гостей (id: main, williams_scanner)
default_user_pages = ["main"]
guest_pages = ["main"]
# Если allow_registration = true — необязательный код приглашения
registration_key = ""
# Путь к users.json относительно корня проекта
users_file = "data/users.json"
# SQLite: сессии и журнал входов
auth_db = "data/auth.sqlite3"
access_token_ttl_min = 60
refresh_token_ttl_days = 7
# Автозавершение сессии без активности (дней)
session_inactivity_days = 30

# SMTP для писем подтверждения регистрации
[auth.smtp]
host = "smtp.example.com"
port = 587
use_tls = true
user = "smtp-user"
password = "smtp-password"
from_email = "noreply@example.com"
from_name = "Order Flow Analyzer"
# Публичный URL приложения (ссылка в письме)
base_url = "http://localhost:8501"
# Альтернатива dev_log_verification в [auth]:
# dev_log_token = true

# Telegram-уведомления Cripto Scanner (опционально)
[telegram]
# bot_token = "123456789:AA..."
# chat_id = "123456789"   # ваш user id или id группы/канала
# proxy = "http://127.0.0.1:7890"   # если api.telegram.org недоступен (VPN/Clash)
# proxy = "socks5://127.0.0.1:1080"
# enabled = true
